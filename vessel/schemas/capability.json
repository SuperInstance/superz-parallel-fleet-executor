{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAPABILITY.toml Schema",
  "description": "Schema for git-agent CAPABILITY.toml files used in fleet discovery",
  "type": "object",
  "required": ["agent", "capability"],
  "properties": {
    "agent": {
      "type": "object",
      "required": ["name", "type", "role"],
      "properties": {
        "name": {"type": "string", "description": "Agent display name"},
        "type": {"type": "string", "enum": ["git-agent", "lighthouse", "quartermaster"], "description": "Agent type in fleet"},
        "role": {"type": "string", "description": "Agent's primary role"},
        "description": {"type": "string", "description": "Extended description of the agent"},
        "version": {"type": "string", "description": "Semantic version of the agent config"},
        "created": {"type": "string", "format": "date", "description": "Date the agent was created"},
        "repos_primary": {"type": "array", "items": {"type": "string"}, "description": "Primary repos this agent works in"},
        "repos_associated": {"type": "array", "items": {"type": "string"}, "description": "Associated repos"}
      }
    },
    "capability": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain", "confidence"],
        "properties": {
          "domain": {"type": "string", "description": "Capability domain name"},
          "specialization": {"type": "array", "items": {"type": "string"}, "description": "Specific skills within this domain"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1, "description": "Confidence score (0-1)"},
          "last_used": {"type": "string", "format": "date", "description": "Last date this capability was used"},
          "description": {"type": "string", "description": "Extended description of this capability"},
          "examples": {"type": "array", "items": {"type": "string"}, "description": "Examples of applying this capability"}
        }
      }
    },
    "skills": {
      "type": "object",
      "description": "Boolean skill flags for quick fleet matching",
      "additionalProperties": {"type": "boolean"}
    },
    "communication": {
      "type": "object",
      "description": "Communication protocols supported",
      "additionalProperties": {"type": "boolean"}
    },
    "constraints": {
      "type": "object",
      "properties": {
        "max_wave_size": {"type": "integer", "minimum": 1},
        "max_task_duration": {"type": "string"},
        "requires_lighthouse": {"type": "boolean"},
        "refuses": {"type": "array", "items": {"type": "string"}},
        "quality_standards": {"type": "array", "items": {"type": "string"}}
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "compute": {"type": "string"},
        "required_apis": {"type": "array", "items": {"type": "string"}},
        "optional_apis": {"type": "array", "items": {"type": "string"}},
        "languages": {"type": "array", "items": {"type": "string"}}
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "sessions": {"type": "integer"},
        "cumulative_lines": {"type": "integer"},
        "cumulative_files": {"type": "integer"},
        "cumulative_pushes": {"type": "integer"},
        "last_active": {"type": "string", "format": "date"}
      }
    }
  }
}
